# Copy to `.env` (git-ignored) and fill in. NEVER commit real secrets.
# This project does not require any secret to run the local benchmarks; a
# Hugging Face token is only needed if you switch to a gated model.

# Optional: Hugging Face token for gated/private models (public Qwen needs none).
HUGGING_FACE_HUB_TOKEN=hf_your_token_here

# Optional: where AirLLM writes per-layer shards (defaults to ./layer_shards).
AIRLLM_SHARDS=D:\airllm_shards
